{
  "name": "@viacerta/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "lighthouse": "lhci autorun"
  },
  "size-limit": [
    {
      "name": "main bundle",
      "path": "dist/assets/index-*.js",
      "limit": "150 kB",
      "gzip": true
    },
    {
      "name": "vendor bundle",
      "path": "dist/assets/vendor-*.js",
      "limit": "80 kB",
      "gzip": true
    },
    {
      "name": "query bundle",
      "path": "dist/assets/query-*.js",
      "limit": "20 kB",
      "gzip": true
    },
    {
      "name": "charts bundle",
      "path": "dist/assets/charts-*.js",
      "limit": "5 kB",
      "gzip": true
    },
    {
      "name": "stylesheet",
      "path": "dist/assets/index-*.css",
      "limit": "10 kB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@tanstack/react-query": "^5.28.0",
    "@viacerta/api-client": "workspace:*",
    "@viacerta/design-tokens": "workspace:*",
    "@viacerta/ui": "workspace:*",
    "@viacerta/utils": "workspace:*",
    "axios": "^1.6.7",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.358.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.4.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^24.0.0",
    "msw": "^2.2.0",
    "postcss": "^8.4.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  }
}
